};
document.querySelector('.container')?.appendChild(importBtn);
</script>
<script>
// Offline indicator
const offlineIndicator = document.createElement('div');
offlineIndicator.textContent = '⚠️ Offline';
offlineIndicator.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#ff6b6b;color:white;text-align:center;padding:5px;display:none;';
document.body.appendChild(offlineIndicator);
window.addEventListener('online', () => offlineIndicator.style.display = 'none');
window.addEventListener('offline', () => offlineIndicator.style.display = 'block');
</script>
<style>
@media (max-width: 768px) {
    .container { padding: 10px; }
    h1 { font-size: 1.5rem; }
    button { width: 100%; margin: 5px 0; }
}
</style>
<script>
// Usage stats
const stats = JSON.parse(localStorage.getItem('app-stats') || '{}');
stats.visits = (stats.visits || 0) + 1;
stats.lastVisit = new Date().toISOString();
localStorage.setItem('app-stats', JSON.stringify(stats));
console.log('Visits:', stats.visits);
</script>
<script>
// Request notification permission
if ('Notification' in window && Notification.permission === 'default') {
    Notification.requestPermission();
}
function notify(title, body) {
    if (Notification.permission === 'granted') {
        new Notification(title, { body });
    }
}
</script>
<script>
// Auto-save to localStorage
const saveKey = 'app-data-' + location.pathname;
const saveData = () => {
    const data = { timestamp: Date.now(), inputs: {} };
    document.querySelectorAll('input, textarea').forEach(el => {
        data.inputs[el.id || el.name] = el.value;
    });
    localStorage.setItem(saveKey, JSON.stringify(data));
};
const loadData = () => {
    const saved = localStorage.getItem(saveKey);
    if (saved) {
        const data = JSON.parse(saved);
        Object.entries(data.inputs).forEach(([key, value]) => {
            const el = document.getElementById(key) || document.querySelector('[name="' + key + '"]');
            if (el) el.value = value;
        });
    }
};
document.addEventListener('input', saveData);
document.addEventListener('DOMContentLoaded', loadData);
</script>
